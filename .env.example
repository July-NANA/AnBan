# GitHub
GITHUB_TOKEN=

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Local-only database placeholders; replace them in your untracked .env if needed.
DATABASE_URL=postgres://anban:local-development-only@127.0.0.1:5432/anban
ANBAN_TEST_DATABASE_URL=postgres://anban:local-test-only@127.0.0.1:5433/anban_test

# LLM Provider
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
# Defaults to json_schema. Set json_object only for Provider/models that support
# JSON Object mode but reject OpenAI Structured Outputs JSON Schema.
OPENAI_COMPATIBLE_RESPONSE_FORMAT_MODE=json_schema
# Limits each Provider HTTP request. Allowed range: 1000-120000ms.
OPENAI_COMPATIBLE_REQUEST_TIMEOUT_MS=60000
# Global upper bound for each Tool invocation. Allowed range: 100-60000ms.
ANBAN_TOOL_INVOCATION_TIMEOUT_MS=10000
# Absolute cap for one governed Skill execution. Allowed range: 1000-1800000ms.
ANBAN_MAX_SKILL_EXECUTION_TIMEOUT_MS=1200000
ANBAN_MAX_MODEL_TURNS=32
ANBAN_MAX_TOOL_CALLS=32
ANBAN_MAX_WRITE_CALLS=32
ANBAN_MAX_IDENTICAL_TOOL_CALLS=3
ANBAN_MAX_NO_PROGRESS_TURNS=5
ANBAN_MAX_OBSERVATION_BYTES=32768
ANBAN_MAX_TOTAL_OBSERVATION_BYTES=262144
ANBAN_MAX_OBSERVATION_HISTORY=8

# Optional Anban workspace root.
# When empty, use the operating-system application data directory.
ANBAN_WORKSPACE_DIR=

# Optional explicit opt-in for the ignored, real-network ClawHub search smoke.
# Default automated Gates never read this value or access ClawHub.
ANBAN_CLAWHUB_REAL_SMOKE=

# Optional Workspace defaults store names and references only, never credential values.
ANBAN_WORKSPACE_MODEL_PROVIDER=openai-compatible
ANBAN_WORKSPACE_MODEL=
ANBAN_WORKSPACE_MODEL_BASE_URL_ENV=OPENAI_COMPATIBLE_BASE_URL
ANBAN_WORKSPACE_MODEL_API_KEY_ENV=OPENAI_COMPATIBLE_API_KEY

# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=3000
API_HOST=127.0.0.1
API_PORT=8080

# Optional loopback ports for an isolated Playwright Gate. Defaults are 8080/3000.
ANBAN_E2E_API_PORT=8080
ANBAN_E2E_WEB_PORT=3000
