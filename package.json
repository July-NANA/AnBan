{
  "name": "anban-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "check:python": "conda run -n anban ruff format --check . && conda run -n anban ruff check . && conda run -n anban python scripts/run_pyright.py && conda run -n anban pytest",
    "check": "pnpm check:python && pnpm --dir apps/web check",
    "build": "pnpm --dir apps/web build",
    "doctor": "conda run -n anban python -m scripts.doctor",
    "acceptance:model": "conda run -n anban python -m scripts.acceptance.check_real_model",
    "acceptance:skill": "conda run -n anban python -m scripts.acceptance.check_real_skill"
  }
}
